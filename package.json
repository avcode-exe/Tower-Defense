{
  "name": "tower-defense",
  "version": "1.2.0-beta.1",
  "description": "Tower Defense Game",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.towerdefense.app",
    "productName": "Tower Defense",
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "avcode-exe",
      "repo": "Tower-Defense",
      "releaseType": "release"
    },
    "files": [
      "electron-main.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "icon.png"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.1"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}