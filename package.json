{
  "name": "tower-defense",
  "version": "1.4.0",
  "description": "Tower Defense Game",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always",
    "lint": "eslint js/ electron-main.js preload.js",
    "lint:fix": "eslint --fix js/ electron-main.js preload.js",
    "format": "prettier --write \"js/**/*.js\" \"*.js\" \"css/**/*.css\"",
    "test": "echo \"No tests yet — add Vitest and write tests in tests/\" && exit 0"
  },
  "build": {
    "appId": "com.towerdefense.app",
    "productName": "Tower Defense",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "avcode-exe",
      "repo": "Tower-Defense"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "icon.png"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.1"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  }
}
