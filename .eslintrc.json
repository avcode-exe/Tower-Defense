{
  "env": {
    "browser": true,
    "worker": true,
    "es2020": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["electron-main.js", "preload.js"],
      "env": {
        "browser": false,
        "node": true
      }
    }
  ],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "error",
    "no-redeclare": "off",
    "eqeqeq": ["warn", "smart"],
    "no-constant-condition": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-unreachable": "error",
    "no-duplicate-case": "error"
  }
}
